# GroundTruth Environment Configuration

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://groundtruth:groundtruth_dev@localhost:5432/groundtruth
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=groundtruth
DATABASE_USER=groundtruth
DATABASE_PASSWORD=groundtruth_dev

# ── LLM Configuration ────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Embedding Settings ────────────────────────────────────
EMBEDDING_DIMENSIONS=1536

# ── Chunking Settings ────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval Settings ───────────────────────────────────
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7

# ── Refusal Settings ─────────────────────────────────────
REFUSAL_CONFIDENCE_THRESHOLD=0.5

# ── Application ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
