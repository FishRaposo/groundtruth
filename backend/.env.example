# GroundTruth Backend Configuration

# Database
DATABASE_URL=postgresql+asyncpg://groundtruth:groundtruth_dev@localhost:5432/groundtruth
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=groundtruth
DATABASE_USER=groundtruth
DATABASE_PASSWORD=groundtruth_dev

# OpenAI
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100
EMBEDDING_CACHE_ENABLED=true

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.7

# Query
REFUSAL_CONFIDENCE_THRESHOLD=0.5

# Application
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# File uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.md,.html,.docx,.txt
